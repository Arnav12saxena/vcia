# .env.production.example
# Copy to .env.production or set in Vercel/Netlify dashboard
#
# IMPORTANT: Vercel env vars are set in project settings, not this file.
# For Netlify: Site Settings → Build & Deploy → Environment Variables

# Your deployed backend URL (from Render/Railway)
# Example: https://vcia-api.onrender.com
VITE_API_URL=https://YOUR_BACKEND_URL_HERE

VITE_APP_ENV=production
