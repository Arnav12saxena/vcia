# .env.example — Copy to .env for local development
# In production, set these in Render/Railway dashboard

# CORS — comma-separated list of allowed frontend origins
# For development: leave as-is
# For production: set to your Vercel/Netlify URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# File upload limits
MAX_FILE_MB=500

# Job cleanup — jobs expire after this many hours
JOB_TTL_HOURS=2

# Upload directory (use /tmp or a mounted volume)
UPLOAD_DIR=/tmp/vcia_uploads

# Server port (auto-set by Render/Railway)
PORT=8000
